#pragma version 11
#pragma typetrack false


main:
    intcblock 0 1 4 8 1000001 105120000000
    bytecblock "usdcAssetId" "b" "isPaused" "d" "creator" "reserveBalance" "DEPOSIT:"


    txn OnCompletion
    !
    assert
    txn ApplicationID
    bz main_create_NoOp@11
    pushbytess 0xa0cadf8a 0x539d0c8a 0x8685c687 0x21f1ddff 0x4fc1f9ad 0xdaef9d74 0xb417a864
    txna ApplicationArgs 0
    match bootstrap depositFirst depositMore withdraw fundReserves setPause getBalance
    err

main_create_NoOp@11:


    pushbytes 0xb8447b36
    txna ApplicationArgs 0
    match createApplication
    err



createApplication:


    bytec 4


    txn Sender
    app_global_put


    bytec_2


    intc_0
    app_global_put


    bytec 5


    intc_0
    app_global_put


    intc_1
    return



bootstrap:


    txna ApplicationArgs 1
    dup
    len
    intc_3
    ==
    assert
    btoi


    txn Sender
    intc_0


    bytec 4


    app_global_get_ex
    assert
    ==
    assert


    intc_0


    bytec_0


    app_global_get_ex
    bury 1
    !
    assert


    bytec_0


    dig 1
    app_global_put








    itxn_begin


    global CurrentApplicationAddress
    itxn_field AssetReceiver


    intc_0
    itxn_field AssetAmount
    itxn_field XferAsset







    intc_2
    itxn_field TypeEnum
    intc_0
    itxn_field Fee








    itxn_submit


    pushbytes "Vault bootstrapped"
    log


    intc_1
    return



depositFirst:


    txn GroupIndex
    pushint 2
    -
    dup
    gtxns TypeEnum
    intc_2
    ==
    assert
    txn GroupIndex
    intc_1
    -
    dup
    gtxns TypeEnum
    intc_1
    ==
    assert


    intc_0


    bytec_2


    app_global_get_ex
    assert
    !
    assert


    dig 1
    gtxns XferAsset
    intc_0


    bytec_0


    app_global_get_ex
    assert
    ==
    assert


    dig 1
    gtxns AssetReceiver
    global CurrentApplicationAddress
    ==
    assert


    swap
    gtxns AssetAmount
    dup
    intc 4
    >=
    assert


    txn Sender


    bytec_3
    dig 1
    concat


    dup
    box_len
    bury 1
    !
    assert


    dig 3
    gtxns Receiver
    global CurrentApplicationAddress
    ==
    assert


    uncover 3
    gtxns Amount
    pushint 257000
    >=
    assert


    uncover 2
    itob
    swap
    dig 1
    box_put


    global Round


    bytec_1
    uncover 3
    concat


    swap
    itob
    box_put


    bytec 6
    swap
    concat
    log


    intc_1
    return



depositMore:


    txn GroupIndex
    intc_1
    -
    dup
    gtxns TypeEnum
    intc_2
    ==
    assert


    intc_0


    bytec_2


    app_global_get_ex
    assert
    !
    assert


    dup
    gtxns XferAsset
    intc_0


    bytec_0


    app_global_get_ex
    assert
    ==
    assert


    dup
    gtxns AssetReceiver
    global CurrentApplicationAddress
    ==
    assert


    gtxns AssetAmount
    dup
    intc 4
    >=
    assert


    txn Sender


    bytec_3
    dig 1
    concat


    dup
    box_len
    bury 1
    assert


    dig 1
    callsub accrueYield


    dup
    box_get
    assert
    btoi


    dig 3
    +
    itob
    box_put


    global Round


    bytec_1
    uncover 2
    concat


    swap
    itob
    box_put


    itob
    bytec 6
    swap
    concat
    log


    intc_1
    return



withdraw:


    txna ApplicationArgs 1
    dup
    len
    intc_3
    ==
    assert
    btoi


    intc_0


    bytec_2


    app_global_get_ex
    assert
    !
    assert


    txn Sender


    dup
    callsub accrueYield


    bytec_3
    dig 1
    concat


    dup
    box_get
    swap
    btoi
    intc_0
    swap
    uncover 2
    select


    dup
    dig 4
    >=
    assert


    dig 3
    -
    itob
    box_put


    global Round


    bytec_1
    dig 2
    concat


    swap
    itob
    box_put








    itxn_begin


    intc_0


    bytec_0


    app_global_get_ex
    assert
    swap
    itxn_field AssetReceiver
    dig 1
    itxn_field AssetAmount
    itxn_field XferAsset







    intc_2
    itxn_field TypeEnum
    intc_0
    itxn_field Fee








    itxn_submit


    itob
    pushbytes "WITHDRAW:"
    swap
    concat
    log


    intc_1
    return



fundReserves:


    txn GroupIndex
    intc_1
    -
    dup
    gtxns TypeEnum
    intc_2
    ==
    assert


    txn Sender
    intc_0


    bytec 4


    app_global_get_ex
    assert
    ==
    assert


    dup
    gtxns XferAsset
    intc_0


    bytec_0


    app_global_get_ex
    assert
    ==
    assert


    dup
    gtxns AssetReceiver
    global CurrentApplicationAddress
    ==
    assert


    intc_0


    bytec 5


    app_global_get_ex
    assert
    swap
    gtxns AssetAmount
    +


    bytec 5


    swap
    app_global_put


    pushbytes "RESERVES_FUNDED"
    log


    intc_1
    return



setPause:


    txna ApplicationArgs 1
    dup
    len
    intc_1
    ==
    assert
    intc_0
    getbit


    txn Sender
    intc_0


    bytec 4


    app_global_get_ex
    assert
    ==
    assert


    bytec_2


    swap
    app_global_put


    intc_1
    return



getBalance:


    txna ApplicationArgs 1
    dup
    len
    pushint 32
    ==
    assert


    bytec_3
    dig 1
    concat


    box_get
    swap
    btoi
    intc_0
    swap
    uncover 2
    select
    dup
    uncover 2


    bytec_1
    swap
    concat


    global Round
    swap
    box_get
    swap
    btoi
    swap
    select


    global Round
    swap
    -
    swap


    bz getBalance_after_if_else@4
    dup
    bz getBalance_after_if_else@4


    dig 1
    dup
    pushint 600
    *


    dig 2
    mulw


    intc 5
    divw


    +

getBalance_after_inlined_smart_contracts/yield_vault/contract.algo.ts::YieldVault.getBalance@5:


    itob
    pushbytes 0x151f7c75
    swap
    concat
    log
    intc_1
    return

getBalance_after_if_else@4:
    dig 1


    b getBalance_after_inlined_smart_contracts/yield_vault/contract.algo.ts::YieldVault.getBalance@5



accrueYield:


    proto 1 0
    intc_0
    pushbytes ""
    dup


    bytec_3
    frame_dig -1
    concat
    dup


    box_get
    swap
    btoi
    intc_0
    swap
    uncover 2
    select
    dup


    bnz accrueYield_after_if_else@2


    global Round


    bytec_1
    frame_dig -1
    concat


    swap
    itob
    box_put


    retsub

accrueYield_after_if_else@2:


    bytec_1
    frame_dig -1
    concat
    dup
    frame_bury 0


    global Round
    swap
    box_get
    swap
    btoi
    swap
    select


    global Round
    swap
    -
    dup
    frame_bury 1


    bz accrueYield_after_if_else@6


    frame_dig 4
    pushint 600
    *


    frame_dig 1
    mulw


    intc 5
    divw
    dup
    frame_bury 2


    bz accrueYield_after_if_else@6


    frame_dig 4
    frame_dig 2
    +
    itob
    frame_dig 3
    swap
    box_put

accrueYield_after_if_else@6:


    global Round
    itob
    frame_dig 0
    swap
    box_put
    retsub
